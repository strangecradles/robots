<mujoco model="panda pick-and-place teleop">
  <include file="panda.xml"/>

  <statistic center="0.4 0 0.3" extent="1.1"/>

  <visual>
    <headlight diffuse="0.55 0.55 0.55" ambient="0.32 0.32 0.32" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="1280" offheight="960"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0.05 0.05 0.1" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.15"/>
    <material name="cube_mat" rgba="0.9 0.35 0.1 1"/>
    <material name="bin_mat" rgba="0.25 0.55 0.9 1"/>
  </asset>

  <worldbody>
    <light pos="0.4 0 1.6" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Operator camera: this exact view is rendered to the headset display.
         Side view: screen-right is world +x, screen-up (in plane) is world +y. -->
    <camera name="teleop_cam" pos="0.45 -0.95 0.7" xyaxes="1 0 0 0 0.4281 0.9037" fovy="50"/>

    <!-- Graspable cube (half-size 0.02 m fits the 0.08 m gripper stroke). -->
    <body name="cube" pos="0.55 -0.1 0.02">
      <freejoint name="cube_freejoint"/>
      <geom name="cube_geom" type="box" size="0.02 0.02 0.02" material="cube_mat"
        condim="4" friction="1 0.02 0.0005" solimp="0.95 0.99 0.001" solref="0.004 1" mass="0.05"/>
    </body>

    <!-- Drop bin: static open-top box. -->
    <body name="bin" pos="0.45 0.28 0">
      <geom name="bin_base" type="box" size="0.06 0.06 0.004" pos="0 0 0.004" material="bin_mat"/>
      <geom name="bin_wall_xp" type="box" size="0.004 0.06 0.025" pos="0.064 0 0.025" material="bin_mat"/>
      <geom name="bin_wall_xn" type="box" size="0.004 0.06 0.025" pos="-0.064 0 0.025" material="bin_mat"/>
      <geom name="bin_wall_yp" type="box" size="0.068 0.004 0.025" pos="0 0.064 0.025" material="bin_mat"/>
      <geom name="bin_wall_yn" type="box" size="0.068 0.004 0.025" pos="0 -0.064 0.025" material="bin_mat"/>
    </body>

    <!-- Visual-only marker for the diff-IK end-effector target (no collisions). -->
    <body name="target" mocap="true" pos="0.4 0 0.35">
      <geom name="target_marker" type="sphere" size="0.012" rgba="0.2 0.9 0.3 0.45"
        contype="0" conaffinity="0" group="2"/>
    </body>
  </worldbody>

  <keyframe>
    <key name="home"
      qpos="0 0 0 -1.57079 0 1.57079 -0.7853 0.04 0.04 0.55 -0.1 0.02 1 0 0 0"
      ctrl="0 0 0 -1.57079 0 1.57079 -0.7853 255"/>
  </keyframe>
</mujoco>
